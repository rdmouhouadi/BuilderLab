# .dockerignore
# Prevents these from being copied into the Docker build context —
# keeps the build fast and avoids leaking secrets or bloating the image.

node_modules
.next
.git
.env
.env.local
.env.production.local

# Test artifacts — not needed inside the container
/coverage
/test-results
/playwright-report
/blob-report
/playwright/.cache

# OS / editor files
.DS_Store
*.pem

# Docs and other large non-runtime content
docs

# Docker itself doesn't need to be copied into the image
Dockerfile
docker-compose.yml
.dockerignore